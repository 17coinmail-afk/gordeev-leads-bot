[Unit]
Description=Freelance Aggregator Bot
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/freelance-bot
Environment="PYTHONUNBUFFERED=1"
EnvironmentFile=/opt/freelance-bot/.env
ExecStart=/opt/freelance-bot/.venv/bin/python main.py
Restart=always
RestartSec=10
StartLimitInterval=60s
StartLimitBurst=3

[Install]
WantedBy=multi-user.target
